---
import type { CollectionEntry } from 'astro:content';
import { getMediaImage } from '../../utils/media';

interface Props {
  post: CollectionEntry<'postsEN'> | CollectionEntry<'postsJA'>;
  lang: 'en' | 'ja';
}

const { post, lang } = Astro.props;
const title = post.data.title;
const summary = post.data.summary;
const date = new Date(post.data.publishedDate).toLocaleDateString(lang === 'ja' ? 'ja-JP' : undefined, { dateStyle: 'long' });
const href = `/${lang}/blog/${post.slug}`;

const coverImageSrc = await getMediaImage(post.data.coverImage);
---

<article class="relative h-[500px] rounded-3xl overflow-hidden shadow-xl mb-12 group">
  {coverImageSrc ? (
    <img 
      src={coverImageSrc} 
      alt={title} 
      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
    />
  ) : (
    <div class="w-full h-full bg-gradient-to-br from-gray-200 to-gray-300 dark:from-gray-800 dark:to-gray-900"></div>
  )}
  
  <div class="absolute inset-0 bg-gradient-to-t from-white/90 via-white/50 to-transparent dark:from-black/90 dark:via-black/50 dark:to-transparent flex flex-col justify-end p-8 sm:p-12">
    <div class="transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
      <span class="inline-block px-3 py-1 bg-primary text-white text-xs font-bold rounded-full mb-4">
        Featured
      </span>
      <h2 class="text-3xl sm:text-5xl font-bold text-gray-900 dark:text-white mb-4 leading-tight">
        <a href={href} class="focus:outline-none hover:underline decoration-primary decoration-2 underline-offset-4">
          <span class="absolute inset-0"></span>
          {title}
        </a>
      </h2>
      <div class="flex items-center text-gray-600 dark:text-gray-300 text-sm mb-4">
        <span>{date}</span>
        {post.data.author && (
          <>
            <span class="mx-2">•</span>
            <span>{post.data.author}</span>
          </>
        )}
      </div>
      <p class="text-gray-700 dark:text-gray-200 text-lg line-clamp-2 max-w-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-300 delay-100">
        {summary}
      </p>
    </div>
  </div>
</article>