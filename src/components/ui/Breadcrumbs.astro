---
const { pathname } = Astro.url;
const segments = pathname.split('/').filter(Boolean);

const lang = segments[0];
const isJa = lang === 'ja';

// Map specific slugs to readable names if needed
const nameMap: Record<string, string> = {
  'blog': isJa ? 'ブログ' : 'Blog',
  'category': isJa ? 'カテゴリー' : 'Category',
  'archive': isJa ? 'アーカイブ' : 'Archive',
  'members': isJa ? 'リーダー' : 'Members',
  'about': isJa ? '私たちについて' : 'About',
  'events': isJa ? 'イベント' : 'Events',
  'join': isJa ? '参加する' : 'Join',
  'news': isJa ? 'ニュース' : 'News',
};

// Generate breadcrumb items
const breadcrumbs = segments.map((segment, index) => {
  const href = `/${segments.slice(0, index + 1).join('/')}`;
  const label = nameMap[segment] || segment.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase()); // simple title case
  return { href, label, isLast: index === segments.length - 1 };
});
---

<nav aria-label="Breadcrumb" class="mb-6">
  <ol class="flex items-center space-x-2 text-sm text-gray-500 dark:text-gray-400">
    <li>
      <a href={`/${lang}`} class="hover:text-primary transition-colors flex items-center">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
      </a>
    </li>
    {breadcrumbs.slice(1).map((crumb) => (
      <li class="flex items-center">
        <svg class="w-4 h-4 text-gray-300 dark:text-gray-600 mx-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        {crumb.isLast ? (
          <span class="font-medium text-gray-900 dark:text-white line-clamp-1 max-w-[200px]" aria-current="page">
            {crumb.label}
          </span>
        ) : (
          <a href={crumb.href} class="hover:text-primary transition-colors">
            {crumb.label}
          </a>
        )}
      </li>
    ))}
  </ol>
</nav>
