---
import { getEntry } from 'astro:content';
import { getLangFromUrl, getLink } from '../utils/i18n';
import { SocialIcon } from './ui/Icons';

const currentYear = new Date().getFullYear();
const currentLang = getLangFromUrl(Astro.url);

const globalEntry = await getEntry('global', currentLang);
if (!globalEntry) {
  throw new Error(`Global content not found for language: ${currentLang}`);
}
const t = globalEntry.data;
---

<footer class="bg-white dark:bg-gray-950 text-gray-900 dark:text-gray-300 border-t border-gray-200 dark:border-gray-800 mt-auto transition-colors duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <a href={getLink('/', currentLang)} class="block mb-4">
          <img src="/icon/logo.svg" alt="KeyAstro" class="h-12 w-auto" />
        </a>
        <p class="text-gray-600 dark:text-gray-400 text-sm whitespace-pre-line">
          {t.footerDescription}
        </p>
      </div>

      <!-- Sitemap -->
      <div>
        <h3 class="text-lg font-semibold mb-4 text-gray-900 dark:text-white">{t.footerLinksTitle}</h3>
        <ul class="space-y-2 text-gray-600 dark:text-gray-400 text-sm">
          <li><a href={getLink('/', currentLang)} class="hover:text-primary transition-colors">{t.navHome}</a></li>
          <li><a href={getLink('/about', currentLang)} class="hover:text-primary transition-colors">{t.navAbout}</a></li>
          <li><a href={getLink('/members', currentLang)} class="hover:text-primary transition-colors">{t.navMembers}</a></li>
          <li><a href={getLink('/blog', currentLang)} class="hover:text-primary transition-colors">{t.navBlog}</a></li>
          <li><a href={getLink('/events', currentLang)} class="hover:text-primary transition-colors">{t.navEvents}</a></li>
          <li><a href={getLink('/join', currentLang)} class="hover:text-primary transition-colors">{t.navJoin}</a></li>
          <li><a href={getLink('/contact', currentLang)} class="hover:text-primary transition-colors">{t.navContact || 'Contact'}</a></li>
        </ul>
      </div>

      <!-- Connect (Dynamic Social Links) -->
      <div>
        <h3 class="text-lg font-semibold mb-4 text-gray-900 dark:text-white">{t.footerConnectTitle}</h3>
        <ul class="space-y-2 text-gray-600 dark:text-gray-400 text-sm">
          {t.socialLinks?.map((link) => (
            <li>
              <a href={link.url} target="_blank" rel="noopener noreferrer" class="hover:text-primary transition-colors flex items-center gap-2">
                <SocialIcon name={link.icon} className="w-5 h-5" />
                <span>{link.platform}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
    <div class="mt-8 pt-8 border-t border-gray-200 dark:border-gray-800 flex flex-col-reverse md:flex-row justify-between items-center gap-4 text-gray-500 dark:text-gray-600 text-sm">
      <div class="text-center md:text-left">
        &copy; {currentYear} KeyAstro. {t.footerRightsText}
      </div>
      <div class="flex gap-6">
        <a href={getLink('/privacy-policy', currentLang)} class="hover:text-primary transition-colors">{t.navPrivacy || 'Privacy Policy'}</a>
      </div>
    </div>
  </div>
</footer>