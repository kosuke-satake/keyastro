---
import Layout from '../../layouts/Layout.astro';
import { getEntry } from 'astro:content';
import { SocialIcon } from '../../components/ui/Icons';
import FAQAccordion from '../../components/sections/FAQAccordion';
import { ScrollReveal } from '../../components/ui/ScrollReveal';
import { getMediaImage } from '../../utils/media';

const entry = await getEntry('join', 'ja');
const global = await getEntry('global', 'ja');

if (!entry) throw new Error('Join page data not found');
const t = entry.data;
const socialLinksRaw = global?.data?.socialLinks || [];
const socialLinks = await Promise.all(
  socialLinksRaw.map(async (link) => ({
    ...link,
    customIcon: await getMediaImage(link.customIcon)
  }))
);

// Fallback if data is missing
const steps = t.joinSteps && t.joinSteps.length > 0 ? t.joinSteps : [
  { icon: '📅', title: 'イベントを確認', desc: 'カレンダーやInstagramをチェック．' },
  { icon: '📍', title: '会場へ行く', desc: '予約は不要です．直接会場へお越しください．' },
  { icon: '🍕', title: '楽しむ', desc: '食事，ゲーム，新しい友達との会話を楽しみましょう．' },
];
---

<Layout title={t.title}>
  <div class="bg-primary text-white pt-40 pb-24 transition-colors duration-300 relative overflow-hidden">
    {/* Background decoration */}
    <div class="absolute inset-0 overflow-hidden pointer-events-none opacity-20">
      <div class="absolute -top-24 -right-24 w-96 h-96 bg-white rounded-full blur-[100px]"></div>
      <div class="absolute bottom-0 left-0 w-64 h-64 bg-blue-400 rounded-full blur-[80px]"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
      <h1 class="text-4xl font-extrabold sm:text-6xl tracking-tight mb-6 drop-shadow-sm">{t.title}</h1>
      <p class="mt-4 text-xl text-blue-100 dark:text-gray-300 max-w-2xl mx-auto font-light">{t.subtitle}</p>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-32">
    
    {/* General Membership Section - Revamped */}
    <ScrollReveal width="100%" client:visible>
      <section class="relative bg-white dark:bg-gray-800 rounded-3xl shadow-xl overflow-hidden border border-gray-100 dark:border-gray-700">
        <div class="grid lg:grid-cols-5 h-full">
          
          {/* Content Side */}
          <div class="lg:col-span-3 p-8 md:p-12 flex flex-col justify-center relative z-10">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 text-xs font-bold uppercase tracking-wider mb-6 w-fit">
              <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
              {t.membershipBadge || "誰でも参加可能"}
            </div>
            
            <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-6">{t.membershipTitle}</h2>
            <p class="text-gray-600 dark:text-gray-300 text-lg leading-relaxed whitespace-pre-line mb-10">
              {t.membershipContent}
            </p>

            {t.membershipButtonLink && (
              <div class="mb-10">
                <a 
                  href={t.membershipButtonLink} 
                  target="_blank" 
                  rel="noopener noreferrer"
                  class="inline-flex items-center justify-center px-6 py-3 bg-primary text-white rounded-full font-bold hover:bg-primary-hover transition-all transform hover:scale-105 shadow-lg shadow-primary/20"
                >
                  {t.membershipButtonText || "メンバーシップ申請"}
                  <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                </a>
              </div>
            )}

            {/* Visual Steps */}
            <div class="grid grid-cols-3 gap-4 mb-10">
              {steps.map((step) => (
                <div class="text-center group">
                  <div class="w-12 h-12 md:w-16 md:h-16 mx-auto bg-gray-50 dark:bg-gray-700 rounded-2xl flex items-center justify-center text-2xl md:text-3xl shadow-sm mb-3 group-hover:scale-110 transition-transform duration-300 border border-gray-100 dark:border-gray-600">
                    {step.icon}
                  </div>
                  <h4 class="font-bold text-gray-900 dark:text-white text-sm md:text-base">{step.title}</h4>
                  <p class="text-xs text-gray-500 dark:text-gray-400 leading-tight mt-1">{step.desc}</p>
                </div>
              ))}
            </div>
            
            {/* Social Links */}
            <div>
              <p class="text-sm font-bold text-gray-400 uppercase tracking-wider mb-4">{t.followTitle || "最新情報をフォロー"}</p>
              <div class="flex flex-wrap gap-3">
                {socialLinks.map((link) => (
                  <a 
                    href={link.url} 
                    target="_blank" 
                    rel="noopener noreferrer" 
                    class="flex items-center gap-2 px-4 py-2 bg-gray-100 dark:bg-gray-700 rounded-full text-gray-700 dark:text-gray-200 hover:bg-primary/10 hover:text-primary transition-all hover:-translate-y-0.5"
                  >
                    {link.customIcon ? (
                      <img src={link.customIcon} alt={link.platform} class="w-5 h-5 object-contain" />
                    ) : (
                      <SocialIcon name={link.icon} className="w-5 h-5" />
                    )}
                    <span class="font-medium">{link.platform}</span>
                  </a>
                ))}
              </div>
            </div>
          </div>
          
          {/* Visual Side (Desktop) */}
          <div class="lg:col-span-2 relative hidden lg:block bg-gray-100 dark:bg-gray-900">
             <div class="absolute inset-0 bg-gradient-to-br from-blue-600/20 to-purple-600/20"></div>
             {/* Abstract Community Pattern */}
             <div class="absolute inset-0 flex items-center justify-center overflow-hidden">
                <div class="w-64 h-64 bg-white dark:bg-gray-800 rounded-full flex items-center justify-center shadow-2xl relative z-10 border-8 border-white/50 dark:border-gray-700/50 backdrop-blur-sm">
                   <div class="text-center">
                      <span class="text-6xl mb-2 block">🤝</span>
                      <span class="font-bold text-gray-900 dark:text-white text-lg whitespace-pre-line">{t.visualTagline || "参加費なし．\n友達作り．"}</span>
                   </div>
                </div>
                {/* Floating avatars blobs */}
                <div class="absolute top-10 left-10 w-20 h-20 bg-orange-400 rounded-full opacity-20 blur-xl animate-pulse"></div>
                <div class="absolute bottom-10 right-10 w-24 h-24 bg-blue-500 rounded-full opacity-20 blur-xl animate-pulse delay-700"></div>
             </div>
          </div>
        </div>
      </section>
    </ScrollReveal>

                    {/* Member Recruitment */}

                    <ScrollReveal width="100%" client:visible className="mt-32">

                      <section class="relative bg-white dark:bg-gray-900 p-8 md:p-16 rounded-3xl overflow-hidden shadow-2xl border border-gray-100 dark:border-gray-800">                {/* Abstract shapes */}            <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-primary/10 dark:bg-primary/20 rounded-full blur-[120px] -translate-y-1/2 translate-x-1/2"></div>
            <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-purple-500/10 dark:bg-purple-500/20 rounded-full blur-[100px] translate-y-1/2 -translate-x-1/4"></div>
            
            <div class="relative z-10 grid lg:grid-cols-2 gap-12 items-center">
              <div>
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 text-primary font-bold text-xs uppercase tracking-wider mb-6 border border-primary/20">
                  <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
                  {t.memberBadge || "運営スタッフ募集"}
                </div>
                
                <h2 class="text-3xl md:text-5xl font-bold mb-6 text-gray-900 dark:text-white">{t.memberTitle}</h2>
                <p class="text-gray-600 dark:text-gray-300 text-lg leading-relaxed mb-8">
                  {t.memberContent}
                </p>
                
                                        <div class="flex flex-col sm:flex-row gap-4">
                                          <a 
                                            href={t.applyButtonLink || '#'}
                                            target="_blank" 
                                            rel="noopener noreferrer"
                                            class={`inline-flex items-center justify-center px-8 py-4 bg-primary text-white rounded-full font-bold text-lg hover:bg-primary-hover transition-all transform hover:scale-105 shadow-lg shadow-primary/20 ${!t.applyButtonLink ? 'opacity-50 cursor-not-allowed' : ''}`}
                                          >
                                            {t.applyButtonText}
                                            <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                                          </a>
                                        </div>            <p class="mt-4 text-sm text-gray-500 dark:text-gray-400 flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              {t.applyButtonNote || "リンクは募集期間中のみ有効です．"}
            </p>              </div>
    
              <div class="bg-gray-50 dark:bg-white/5 backdrop-blur-sm rounded-2xl p-8 border border-gray-200 dark:border-white/10">
                <h3 class="text-xl font-bold mb-6 text-gray-900 dark:text-white flex items-center gap-2">
                  <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                  {t.requirementsTitle}
                </h3>
                <ul class="space-y-4">
                  {t.requirementsList.map((req) => (
                    <li class="flex items-start text-gray-600 dark:text-gray-300">
                      <span class="w-1.5 h-1.5 bg-primary rounded-full mt-2.5 mr-3 flex-shrink-0"></span>
                      {req}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </section>
        </ScrollReveal>
    {/* FAQ - Accordion */}
    <ScrollReveal width="100%" client:visible className="mt-32">
      <section>
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">{t.faqTitle}</h2>
          <p class="text-gray-500 dark:text-gray-400">{t.faqSubtitle || "よくある質問"}</p>
        </div>
        <FAQAccordion client:visible items={t.faqList} />
      </section>
    </ScrollReveal>

  </div>
</Layout>