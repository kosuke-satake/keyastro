---
import Layout from '../../../../layouts/Layout.astro';
import Breadcrumbs from '../../../../components/ui/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('postsEN');
const tagCounts: Record<string, number> = {};
allPosts.forEach(p => p.data.tags?.forEach(t => tagCounts[t] = (tagCounts[t]||0) + 1));
const tags = Object.entries(tagCounts).map(([name, count]) => ({ name, count })).sort((a,b) => b.count - a.count);
---

<Layout title="Categories - KeyAstro Blog">
  <div class="bg-gray-50 dark:bg-gray-900 min-h-screen transition-colors duration-300">
    <div class="bg-white dark:bg-gray-950 border-b border-gray-200 dark:border-gray-800 pt-24 pb-16">
      <div class="max-w-7xl mx-auto px-6 lg:px-8 text-center">
        <h1 class="text-4xl font-extrabold text-gray-900 dark:text-white sm:text-6xl mb-4">Categories</h1>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-12">
      <Breadcrumbs />
      <div class="flex flex-wrap gap-4 justify-center">
        {tags.length > 0 ? tags.map((tag) => (
          <a 
            href={`/en/blog/category/${tag.name}`} 
            class="px-6 py-3 bg-white dark:bg-gray-800 rounded-full shadow-sm border border-gray-200 dark:border-gray-700 hover:border-primary hover:text-primary transition-all flex items-center gap-3 text-lg font-medium text-gray-700 dark:text-gray-300"
          >
            {tag.name}
            <span class="bg-gray-100 dark:bg-gray-700 text-sm px-2 py-0.5 rounded-full text-gray-500 dark:text-gray-400">{tag.count}</span>
          </a>
        )) : (
          <p class="text-gray-500">No categories found.</p>
        )}
      </div>
    </div>
  </div>
</Layout>