---
import Layout from '../../../layouts/Layout.astro';
import FeaturedPost from '../../../components/blog/FeaturedPost.astro';
import BlogSidebar from '../../../components/blog/BlogSidebar.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import type { GetStaticPaths, Page } from 'astro';

import { getMediaImage } from '../../../utils/media';

export const prerender = true;

export const getStaticPaths = (async ({ paginate }) => {
  const allPostsRaw = (await getCollection('postsEN')).sort(
    (a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf()
  );

  // Calculate Global Stats
  const tagCounts: Record<string, number> = {};
  allPostsRaw.forEach(p => p.data.tags?.forEach(t => tagCounts[t] = (tagCounts[t]||0) + 1));
  const tags = Object.entries(tagCounts).map(([name, count]) => ({ name, count: Number(count) })).sort((a,b) => b.count - a.count);

  const archiveCounts: Record<number, number> = {};
  allPostsRaw.forEach(p => {
    const y = p.data.publishedDate.getFullYear();
    archiveCounts[y] = (archiveCounts[y]||0) + 1;
  });
  const archive = Object.entries(archiveCounts).map(([year, count]) => ({ year: parseInt(year), count: Number(count) })).sort((a,b) => b.year - a.year);

  const featuredPost = allPostsRaw[0];
  const postsToPaginate = allPostsRaw.slice(1);

  return paginate(postsToPaginate, {
    pageSize: 6,
    props: { featuredPost, tags, archive },
  });
}) satisfies GetStaticPaths;

interface Props {
  page: Page<CollectionEntry<'postsEN'>>;
  featuredPost: CollectionEntry<'postsEN'>;
  tags: { name: string; count: number }[];
  archive: { year: number; count: number }[];
}

const { page, featuredPost, tags, archive } = Astro.props;
const gridPosts = page.data;

const resolvedGridPosts = await Promise.all(gridPosts.map(async (post) => ({
  ...post,
  image: await getMediaImage(post.data.coverImage)
})));
---

<Layout title={`Blog - Page ${page.currentPage} - KeyAstro`}>
  <div class="bg-gray-50 dark:bg-gray-900 min-h-screen transition-colors duration-300">
    
    {/* Header */}
    <div class="bg-white dark:bg-gray-950 border-b border-gray-200 dark:border-gray-800 pt-24 pb-16">
      <div class="max-w-7xl mx-auto px-6 lg:px-8 text-center">
        <h1 class="text-4xl font-extrabold text-gray-900 dark:text-white sm:text-6xl mb-4">Our Blog</h1>
        <p class="text-xl text-gray-500 dark:text-gray-400 max-w-2xl mx-auto">
          Stories, updates, and insights from the KeyAstro community.
        </p>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-12">
      {page.currentPage === 1 && featuredPost && (
        <FeaturedPost post={featuredPost} lang="en" />
      )}

      <div class="grid lg:grid-cols-12 gap-12">
        {/* Sidebar (Mobile: 1st, Desktop: 2nd) */}
        <div class="lg:col-span-4 lg:order-2 space-y-8">
          <BlogSidebar tags={tags} archive={archive} lang="en" />
        </div>

        {/* Main Content (Mobile: 2nd, Desktop: 1st) */}
        <div class="lg:col-span-8 lg:order-1">
          <div class="grid gap-8 sm:grid-cols-2">
            {resolvedGridPosts.map((post) => (
              <article class="flex flex-col bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden hover:shadow-lg transition-all duration-300 hover:-translate-y-1">
                {post.image && (
                  <a href={`/en/blog/${post.slug}`} class="block aspect-video overflow-hidden">
                    <img 
                      src={post.image} 
                      alt={post.data.title} 
                      class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
                    />
                  </a>
                )}
                <div class="p-6 flex-1 flex flex-col">
                  <div class="flex items-center justify-between mb-3">
                    <div class="flex items-center gap-2">
                      {post.data.tags && post.data.tags.length > 0 && (
                        <span class="text-xs font-semibold text-primary bg-primary/10 px-2 py-1 rounded-full">
                          {post.data.tags[0]}
                        </span>
                      )}
                      <span class="text-xs text-gray-500 dark:text-gray-400">
                        {post.data.publishedDate.toLocaleDateString(undefined, { dateStyle: 'medium' })}
                      </span>
                    </div>
                  </div>
                  
                  <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2 line-clamp-2">
                    <a href={`/en/blog/${post.slug}`} class="hover:text-primary transition-colors">
                      {post.data.title}
                    </a>
                  </h3>
                  
                  {post.data.author && (
                    <p class="text-xs text-gray-500 dark:text-gray-400 mb-3 font-medium">
                      By {post.data.author}
                    </p>
                  )}

                  <p class="text-gray-600 dark:text-gray-300 text-sm line-clamp-3 mb-4 flex-1">
                    {post.data.summary}
                  </p>
                  
                  <a href={`/en/blog/${post.slug}`} class="inline-flex items-center text-sm font-medium text-primary hover:text-primary-hover">
                    Read Article →
                  </a>
                </div>
              </article>
            ))}
          </div>
          
          {/* Pagination */}
          <div class="flex justify-center mt-16 gap-4">
            {page.url.prev ? (
              <a href={page.url.prev} class="px-6 py-2 rounded-full border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
                ← Previous
              </a>
            ) : (
              <span class="px-6 py-2 rounded-full border border-gray-200 dark:border-gray-800 text-gray-300 dark:text-gray-600 cursor-not-allowed">
                ← Previous
              </span>
            )}
            
            <span class="px-4 py-2 text-gray-500 dark:text-gray-400 font-mono">
              Page {page.currentPage} of {page.lastPage}
            </span>

            {page.url.next ? (
              <a href={page.url.next} class="px-6 py-2 rounded-full border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
                Next →
              </a>
            ) : (
              <span class="px-6 py-2 rounded-full border border-gray-200 dark:border-gray-800 text-gray-300 dark:text-gray-600 cursor-not-allowed">
                Next →
              </span>
            )}
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
