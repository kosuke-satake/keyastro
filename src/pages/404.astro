---
import Layout from '../layouts/Layout.astro';
import Button from '../components/ui/Button';

export const prerender = true;

// 404 Page
---

<Layout title="Page Not Found | KeyAstro">
  <div class="min-h-[70vh] flex flex-col items-center justify-center text-center px-4">
    <div class="mb-8 relative">
      <h1 class="text-9xl font-black text-gray-200 dark:text-gray-800 select-none">404</h1>
      <div class="absolute inset-0 flex items-center justify-center">
        <span class="text-6xl animate-bounce">🧪</span>
      </div>
    </div>
    
    <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">
      Experiment Not Found
    </h2>
    <p class="text-xl text-gray-600 dark:text-gray-400 max-w-md mb-2">
      The page you are looking for might have been moved, deleted, or never existed.
    </p>
    <p class="text-sm text-gray-500 dark:text-gray-500 mb-8">
      お探しのページは見つかりませんでした．
    </p>

    <div class="flex gap-4">
      <Button as="a" href="/en" variant="primary">
        Go Home (EN)
      </Button>
      <Button as="a" href="/ja" variant="secondary">
        ホームに戻る (JA)
      </Button>
    </div>
  </div>
</Layout>
